# ─── Server Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB — get from MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/whiteboard?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_random_64_char_string

# Redis — optional (leave blank to use in-memory fallback)
REDIS_URL=redis://default:<password>@<host>:<port>

# AI APIs
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_VISION_KEY=AIza...
